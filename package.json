{
  "name": "electron_labyrinthes",
  "version": "1.0.0",
  "description": "Jeu de labyrinthes en Electron",
  "author": "Lucas",
  "license": "ISC",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.lucas.labyrinthes",
    "productName": "Labyrinthes",
    "directories": {
      "buildResources": "build"
    },
    "files": [
      "index.js",
      "front-end/**/*",
      "backend/**/*",
      "package.json"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": "nsis"
    }
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.9.0",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Lucasv9230/Electron_Labyrinthes.git"
  },
  "keywords": [],
  "bugs": {
    "url": "https://github.com/Lucasv9230/Electron_Labyrinthes/issues"
  },
  "homepage": "https://github.com/Lucasv9230/Electron_Labyrinthes#readme"
}
